# NarrativeOS Environment Variables

# ===== CLAUDE API =====
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key-here

# ===== X API =====
X_API_TOKEN=your_x_bearer_token_here
USE_X_API=true

# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/narrativeOS
NODE_ENV=development

# ===== AUTHENTICATION =====
# X OAuth credentials (get from https://developer.twitter.com/en/portal/dashboard)
X_CLIENT_ID=your_x_client_id_here
X_CLIENT_SECRET=your_x_client_secret_here
X_REDIRECT_URI=http://localhost:3001/api/auth/x/callback

# JWT Configuration
JWT_SECRET=your_secure_random_32_character_secret_key_here
JWT_EXPIRY=7d

# ===== REDIS (Optional) =====
REDIS_URL=redis://localhost:6379

# ===== FEATURE FLAGS =====
FEATURE_MULTI_ACCOUNT=true
FEATURE_TEAM_COLLABORATION=true
FEATURE_AGGRESSIVE_AUTOMATION=false
FEATURE_FALLBACK_MOCK_DATA=true

# ===== LOGGING =====
LOG_LEVEL=debug
